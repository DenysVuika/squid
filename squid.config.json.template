{
  "api_url": "http://127.0.0.1:1234/v1",
  "context_window": 32768,
  "log_level": "info",
  "db_log_level": "debug",
  "database_path": "squid.db",
  "server": {
    "allow_network": false
  },
  "rag": {
    "enabled": false,
    "embedding_model": "text-embedding-nomic-embed-text-v1.5",
    "embedding_url": "http://127.0.0.1:1234/v1",
    "chunk_size": 512,
    "chunk_overlap": 50,
    "top_k": 5,
    "documents_path": "documents"
  },
  "agents": {
    "general-assistant": {
      "name": "General Assistant",
      "enabled": true,
      "description": "Full-featured coding assistant with all tools",
      "model": "local-model",
      "context_window": 32768,
      "pricing_model": "gpt-4o-mini",
      "permissions": {
        "allow": [
          "read_file",
          "write_file",
          "grep",
          "bash:ls",
          "bash:git",
          "bash:date"
        ],
        "deny": []
      }
    },
    "code-reviewer": {
      "name": "Code Reviewer",
      "enabled": true,
      "description": "Reviews code for quality and security (read-only)",
      "model": "local-model",
      "context_window": 32768,
      "pricing_model": "gpt-4o-mini",
      "prompt": "{{persona}}\n\nYou are an expert code reviewer working on {{os}} ({{arch}}) at {{now}}. Focus on security vulnerabilities, performance issues, code quality, and maintainability. Provide constructive feedback with specific examples.",
      "permissions": {
        "allow": ["read_file", "grep", "bash:date"],
        "deny": ["write_file"]
      }
    },
    "light": {
      "name": "Light",
      "enabled": true,
      "description": "Lightweight assistant with minimal permissions",
      "model": "local-model",
      "context_window": 8192,
      "pricing_model": "gpt-4o-mini",
      "prompt": "{{persona}}\n\nWhen asked for the current date, time, or day of the week, use the bash tool with the date command if available. If tools are disabled, respond with: Date: {{date}}, Time: {{time}}, Timezone: {{timezone}}.",
      "permissions": {
        "allow": ["bash:date"],
        "deny": []
      }
    }
  },
  "default_agent": "general-assistant"
}
