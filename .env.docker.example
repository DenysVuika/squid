# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env to run Squid with Docker AI models
#
# Required: API_URL, API_MODEL, EMBEDDING_URL, EMBEDDING_MODEL
# These connect Squid to the Docker AI model services
#
# Note: CONTEXT_WINDOW, LOG_LEVEL, and DATABASE_PATH are configured in
# docker-compose.yml. To customize those, edit docker-compose.yml directly.

# -----------------------------------------------------------------------------
# Model Configuration (Required for Docker AI)
# -----------------------------------------------------------------------------
# Docker AI injects model endpoints through these environment variables
# These match the model services defined in docker-compose.yml

API_URL=http://llm:8080/v1
API_MODEL=qwen2.5-coder
EMBEDDING_URL=http://embedding:8080/v1
EMBEDDING_MODEL=nomic-embed-text-v1.5

# -----------------------------------------------------------------------------
# Advanced Configuration (Optional)
# -----------------------------------------------------------------------------
# To customize CONTEXT_WINDOW, LOG_LEVEL, or DATABASE_PATH, edit docker-compose.yml
# For Rust debugging, you can add these to docker-compose.yml environment section:
# RUST_LOG=info
# RUST_BACKTRACE=1

# =============================================================================
# Advanced: Using External LLM Services
# =============================================================================
# If you want to use external services instead of Docker AI models,
# uncomment and configure one of these options:

# -----------------------------------------------------------------------------
# External LM Studio
# -----------------------------------------------------------------------------
# API_URL=http://host.docker.internal:1234/v1
# API_MODEL=local-model

# -----------------------------------------------------------------------------
# External Ollama
# -----------------------------------------------------------------------------
# API_URL=http://host.docker.internal:11434/v1
# API_MODEL=qwen2.5-coder

# -----------------------------------------------------------------------------
# OpenAI Cloud API
# -----------------------------------------------------------------------------
# API_URL=https://api.openai.com/v1
# API_MODEL=gpt-4
# API_KEY=sk-your-api-key-here
# Note: Update CONTEXT_WINDOW in docker-compose.yml if using a different model

# -----------------------------------------------------------------------------
# Mistral Cloud API
# -----------------------------------------------------------------------------
# API_URL=https://api.mistral.ai/v1
# API_MODEL=mistral-large-latest
# API_KEY=your-mistral-api-key
# Note: Update CONTEXT_WINDOW in docker-compose.yml if using a different model

# =============================================================================
# Notes
# =============================================================================
# - Copy this file to .env before running: cp .env.docker.example .env
# - Docker AI requires API_URL, API_MODEL, EMBEDDING_URL, EMBEDDING_MODEL to be set
# - Docker Compose automatically manages models defined in docker-compose.yml
# - Use host.docker.internal to access services on your host machine from container
# - API_KEY is not needed for local models (LM Studio, Ollama, Docker AI)
# - Keep API keys secure - this .env file is gitignored
# - After changing .env, restart containers: docker compose restart
